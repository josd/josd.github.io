#!/usr/bin/env bash

label_width=14

linux_name() {
  lsb_release -ds 2>/dev/null ||
    awk -F= '/^PRETTY_NAME=/ {
      gsub(/"/, "", $2)
      print $2
    }' /etc/os-release
}

network_summary() {
  if ! command -v ip >/dev/null 2>&1; then
    printf "Unavailable (ip command not found)"
    return
  fi

  local interface address gateway

  read -r interface gateway < <(
    ip -4 route show default 2>/dev/null |
      awk 'NR == 1 {
        for (i = 1; i <= NF; i++) {
          if ($i == "dev") {
            interface = $(i + 1)
          } else if ($i == "via") {
            gateway = $(i + 1)
          }
        }

        print interface, gateway
      }'
  )

  # Fall back to the first active interface with a global IPv4 address.
  if [[ -z "$interface" ]]; then
    interface="$(
      ip -o -4 addr show scope global up 2>/dev/null |
        awk 'NR == 1 {print $2}'
    )"
  fi

  if [[ -n "$interface" ]]; then
    address="$(
      ip -o -4 addr show dev "$interface" scope global 2>/dev/null |
        awk 'NR == 1 {print $4}'
    )"
  fi

  if [[ -z "$interface" ]]; then
    printf "Disconnected"
  elif [[ -n "$gateway" ]]; then
    printf "%s %s via %s" "$interface" "${address:-no IPv4}" "$gateway"
  else
    printf "%s %s" "$interface" "${address:-no IPv4}"
  fi
}

print_row() {
  printf "%-${label_width}s %s\n" "$1:" "$2"
}

cpu="$(
  lscpu |
    awk -F: '/Model name/ {
      gsub(/^[ \t]+/, "", $2)
      print $2
      exit
    }'
)"

memory="$(
  awk '/MemTotal/ {
    printf "%.2f GB", $2 / 1024 / 1024
  }' /proc/meminfo
)"

filesystem="$(
  df -h --output=source,fstype,used,size,pcent . |
    awk 'NR == 2 {
      used = $3
      size = $4

      sub(/K$/, "KB", used)
      sub(/M$/, "MB", used)
      sub(/G$/, "GB", used)
      sub(/T$/, "TB", used)

      sub(/K$/, "KB", size)
      sub(/M$/, "MB", size)
      sub(/G$/, "GB", size)
      sub(/T$/, "TB", size)

      printf "%s %s %s/%s %s", $1, $2, used, size, $5
    }'
)"

network="$(network_summary)"
linux="$(linux_name)"
kernel_release="$(uname -r)"

print_row "Processor" "$cpu"
print_row "Memory" "$memory"
print_row "Filesystem" "$filesystem"
print_row "Network" "$network"
print_row "Linux" "$linux"

if grep -qiE 'microsoft|wsl' /proc/sys/kernel/osrelease 2>/dev/null; then
  if [[ "$kernel_release" == *WSL2* ||
        "$kernel_release" == *microsoft-standard* ]]; then
    environment="WSL2"
  else
    environment="WSL1"
  fi

  if command -v cmd.exe >/dev/null 2>&1; then
    host="$(
      cmd.exe /c ver 2>/dev/null |
        tr -d '\r' |
        awk 'NF'
    )"

    [[ -n "$host" ]] && environment="$environment on $host"
  fi
else
  environment="Native Linux"
fi

print_row "Environment" "$environment"
