#!/usr/bin/env bash

label_width=14

print_row() {
  printf "%-${label_width}s %s\n" "$1:" "$2"
}

linux_name() {
  lsb_release -ds 2>/dev/null ||
    awk -F= '
      /^PRETTY_NAME=/ {
        gsub(/"/, "", $2)
        print $2
        exit
      }
    ' /etc/os-release 2>/dev/null
}

format_link_speed() {
  local speed="$1"

  if [[ ! "$speed" =~ ^[0-9]+$ ]] || ((speed <= 0)); then
    return
  fi

  if ((speed >= 1000)); then
    awk -v speed="$speed" '
      BEGIN {
        value = speed / 1000

        if (value == int(value)) {
          printf "%.0f Gb/s", value
        } else {
          printf "%.2f Gb/s", value
        }
      }
    '
  else
    printf "%s Mb/s" "$speed"
  fi
}

network_summary() {
  local interface=""
  local state=""
  local connection_type=""
  local carrier=""
  local speed=""
  local formatted_speed=""
  local path=""
  local name=""

  # Prefer the interface used by the default IPv4 route.
  if [[ -r /proc/net/route ]]; then
    interface="$(
      awk '
        $1 != "Iface" &&
        $1 != "lo" &&
        $2 == "00000000" {
          print $1
          exit
        }
      ' /proc/net/route 2>/dev/null
    )"
  fi

  # Fall back to the first active non-loopback interface.
  if [[ -z "$interface" && -d /sys/class/net ]]; then
    for path in /sys/class/net/*; do
      [[ -e "$path" ]] || continue

      name="${path##*/}"
      [[ "$name" == "lo" ]] && continue

      state="$(cat "$path/operstate" 2>/dev/null)"

      if [[ "$state" == "up" || "$state" == "unknown" ]]; then
        interface="$name"
        break
      fi
    done
  fi

  # Last fallback: any non-loopback interface.
  if [[ -z "$interface" && -d /sys/class/net ]]; then
    for path in /sys/class/net/*; do
      [[ -e "$path" ]] || continue

      name="${path##*/}"
      [[ "$name" == "lo" ]] && continue

      interface="$name"
      break
    done
  fi

  if [[ -z "$interface" ]]; then
    printf "Disconnected"
    return
  fi

  state="$(
    cat "/sys/class/net/$interface/operstate" 2>/dev/null
  )"
  state="${state:-unknown}"

  # Some mobile and virtual interfaces report "unknown" while connected.
  if [[ "$state" == "unknown" ]]; then
    carrier="$(
      cat "/sys/class/net/$interface/carrier" 2>/dev/null
    )"

    case "$carrier" in
      1) state="up" ;;
      0) state="down" ;;
    esac
  fi

  if [[ -d "/sys/class/net/$interface/wireless" ]]; then
    connection_type="Wi-Fi"
  else
    case "$interface" in
      wl*|wifi*)
        connection_type="Wi-Fi"
        ;;
      rmnet*|wwan*|ccmni*|pdp*|mobile*)
        connection_type="Mobile"
        ;;
      tun*|tap*|wg*|vpn*)
        connection_type="VPN/tunnel"
        ;;
      docker*|veth*|br-*|virbr*)
        connection_type="Virtual"
        ;;
      eth*|en*)
        connection_type="Ethernet"
        ;;
      *)
        connection_type="Network"
        ;;
    esac
  fi

  speed="$(
    cat "/sys/class/net/$interface/speed" 2>/dev/null
  )"

  formatted_speed="$(format_link_speed "$speed")"

  if [[ -n "$formatted_speed" ]]; then
    printf "%s (%s, %s, %s)" \
      "$interface" "$connection_type" "$state" "$formatted_speed"
  else
    printf "%s (%s, %s)" \
      "$interface" "$connection_type" "$state"
  fi
}

environment_summary() {
  local kernel_release=""
  local environment=""
  local host=""

  kernel_release="$(uname -r)"

  if grep -qiE 'microsoft|wsl' \
    /proc/sys/kernel/osrelease 2>/dev/null; then

    if [[ "$kernel_release" == *WSL2* ||
          "$kernel_release" == *microsoft-standard* ]]; then
      environment="WSL2"
    else
      environment="WSL1"
    fi

    if command -v cmd.exe >/dev/null 2>&1; then
      host="$(
        cmd.exe /c ver 2>/dev/null |
          tr -d '\r' |
          awk '
            NF {
              sub(/^[[:space:]]+/, "")
              print
              exit
            }
          '
      )"

      if [[ -n "$host" ]]; then
        environment="$environment on $host"
      fi
    fi
  else
    environment="Native Linux"
  fi

  printf "%s" "$environment"
}

cpu="$(
  if command -v lscpu >/dev/null 2>&1; then
    lscpu |
      awk -F: '
        /Model name/ {
          gsub(/^[ \t]+/, "", $2)
          print $2
          exit
        }
      '
  else
    awk -F: '
      /model name|Hardware|Processor/ {
        gsub(/^[ \t]+/, "", $2)
        print $2
        exit
      }
    ' /proc/cpuinfo 2>/dev/null
  fi
)"
[[ -z "$cpu" ]] && cpu="Unknown"

cpu_cores="$(
  if command -v nproc >/dev/null 2>&1; then
    nproc
  else
    awk '
      /^processor/ {
        count++
      }
      END {
        if (count > 0) {
          print count
        }
      }
    ' /proc/cpuinfo 2>/dev/null
  fi
)"
[[ -z "$cpu_cores" ]] && cpu_cores="Unknown"

memory="$(
  awk '
    /^MemTotal:/ {
      total = $2
    }
    /^MemAvailable:/ {
      available = $2
    }
    END {
      if (total > 0) {
        used = total - available

        printf "%.2f GiB/%.2f GiB used",
          used / 1024 / 1024,
          total / 1024 / 1024
      }
    }
  ' /proc/meminfo 2>/dev/null
)"
[[ -z "$memory" ]] && memory="Unavailable"

swap="$(
  awk '
    /^SwapTotal:/ {
      total = $2
    }
    /^SwapFree:/ {
      free_swap = $2
    }
    END {
      if (total == 0) {
        print "Disabled"
      } else {
        used = total - free_swap

        printf "%.2f GiB/%.2f GiB used",
          used / 1024 / 1024,
          total / 1024 / 1024
      }
    }
  ' /proc/meminfo 2>/dev/null
)"
[[ -z "$swap" ]] && swap="Unavailable"

filesystem="$(
  df -B1 --output=source,fstype,used,size,pcent . 2>/dev/null |
    awk '
      NR == 2 {
        gib = 1024 * 1024 * 1024

        printf "%s %s %.2f GiB/%.2f GiB %s",
          $1,
          $2,
          $3 / gib,
          $4 / gib,
          $5
      }
    '
)"
[[ -z "$filesystem" ]] && filesystem="Unavailable"

gpu="$(
  if command -v lspci >/dev/null 2>&1; then
    lspci |
      awk -F': ' '
        /VGA compatible controller|3D controller|Display controller/ {
          print $2
          exit
        }
      '
  else
    printf "Unavailable (lspci not found)"
  fi
)"
[[ -z "$gpu" ]] && gpu="Not detected"

hostname_info="$(
  hostnamectl --static 2>/dev/null ||
    hostname 2>/dev/null
)"
[[ -z "$hostname_info" ]] && hostname_info="Unknown"

uptime_info="$(
  uptime -p 2>/dev/null |
    sed 's/^up //'
)"
[[ -z "$uptime_info" ]] && uptime_info="Unavailable"

load_average="$(
  awk '
    {
      printf "%s %s %s", $1, $2, $3
    }
  ' /proc/loadavg 2>/dev/null
)"
[[ -z "$load_average" ]] && load_average="Unavailable"

network="$(network_summary)"
linux="$(linux_name)"
kernel_release="$(uname -r)"
architecture="$(uname -m)"
shell_info="$(basename "${SHELL:-unknown}")"
environment="$(environment_summary)"

[[ -z "$linux" ]] && linux="Unknown"

print_row "Hostname"     "$hostname_info"
print_row "Processor"    "$cpu"
print_row "CPU cores"    "$cpu_cores"
print_row "Memory"       "$memory"
print_row "Swap"         "$swap"
print_row "Filesystem"   "$filesystem"
print_row "Network"      "$network"
print_row "GPU"          "$gpu"
print_row "Linux"        "$linux"
print_row "Kernel"       "$kernel_release"
print_row "Architecture" "$architecture"
print_row "Shell"        "$shell_info"
print_row "Uptime"       "$uptime_info"
print_row "Load"         "$load_average"
print_row "Environment"  "$environment"
